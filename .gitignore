 # === QuantumTrader-AI™ .gitignore ===
# Maintained by Olagoke Ajibulu (Visionary, Architect & Builder)
# -------------------------------------

# Node modules & system caches
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
pnpm-lock.yaml
.DS_Store

# Logs
logs/
*.log
logs.txt

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build & output directories
dist/
build/
coverage/
.cache/
.tmp/
temp/

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# VS Code & local editor settings
.vscode/
.idea/
*.swp

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini

# Service worker cache & manifests
service-worker.js.map
manifest.webmanifest.map

# Firebase & local emulator data
.firebase/
.firebaserc
.emulator/

# Avoid accidental publishing of test assets
test/
tests/
__tests__/
mock/
*.spec.js

# --- GitHub Pages Safeguard ---
# Keep /docs for deployment (DO NOT IGNORE)
!docs/
!docs/**

# === END QuantumTrader-AI™ .gitignore ===
